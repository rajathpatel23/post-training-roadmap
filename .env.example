WANDB_PROJECT=post-training-roadmap
WANDB_ENTITY=         # your wandb username or team
HF_TOKEN=             # huggingface token if needed for gated models
HF_HOME=~/.cache/huggingface
TOKENIZERS_PARALLELISM=false
ASANA_CLIENT_ID=       # from https://app.asana.com/0/my-apps (OAuth app)
ASANA_CLIENT_SECRET=   # same app; never commit real values—use .env only
